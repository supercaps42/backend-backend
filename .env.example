# Backend environment variables for BananaVision
PORT=5000
NODE_ENV=development
DATABASE_URL=mongodb://localhost:27017/your-db
JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
ML_SERVER_URL=http://localhost:5001
TRUST_PROXY=0

# Firebase service account variables (recommended in production)
# Use one of these methods:
# 1) FIREBASE_SERVICE_ACCOUNT_KEY as JSON string
# 2) FIREBASE_SERVICE_ACCOUNT_PATH path to JSON file
# 3) FIREBASE_PRIVATE_KEY, FIREBASE_CLIENT_EMAIL, FIREBASE_PROJECT_ID
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PROJECT_ID=
